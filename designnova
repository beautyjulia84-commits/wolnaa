<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Designnova Studio – Premium Beauty SaaS</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{overflow-x:hidden;width:100%;max-width:100%}
html{scroll-behavior:smooth}
body{font-family:"Inter",sans-serif;font-weight:300;color:#fff;background:#0d0d0d;line-height:1.7}
:root{--gold:#c9a84c;--gold2:#e2c07a;--dark:#0d0d0d;--dark2:#111;--border:rgba(201,168,76,0.25);--nav-h:68px}
h1,h2,h3{font-family:"Playfair Display",serif;font-weight:700;line-height:1.15}
.ey{font-size:.62rem;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--gold)}
.con{width:100%;max-width:1200px;margin:0 auto;padding:0 clamp(1.25rem,5vw,3rem)}
.btn{display:inline-flex;align-items:center;justify-content:center;padding:.9rem 2rem;font-family:"Inter",sans-serif;font-size:.85rem;font-weight:500;text-decoration:none;border:none;cursor:pointer;transition:all .25s;border-radius:4px}
.bg{background:var(--gold);color:#0d0d0d;font-weight:600}
.bg:hover{background:var(--gold2)}
.bo{background:transparent;color:#fff;border:1px solid rgba(255,255,255,.35)}
.bog{background:transparent;color:var(--gold);border:1px solid var(--gold)}

/* FULLWIDTH — fixes GHL white sides */
.fw{width:100vw;position:relative;left:50%;right:50%;margin-left:-50vw;margin-right:-50vw;overflow:hidden}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:var(--nav-h);display:flex;align-items:center;background:rgba(13,13,13,.97);backdrop-filter:blur(16px);border-bottom:1px solid rgba(201,168,76,.15)}
.ni{display:flex;align-items:center;justify-content:space-between;gap:1rem;width:100%}
.nl{display:flex;align-items:center;gap:2rem;list-style:none}
.nl a{font-size:.73rem;font-weight:400;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.65);text-decoration:none;transition:color .2s}
.nl a:hover{color:var(--gold)}
.hb{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px;background:none;border:none}
.hb span{display:block;width:22px;height:2px;background:var(--gold);border-radius:2px;transition:all .3s}
.hb.open span:nth-child(1){transform:rotate(45deg) translate(5px,5px)}
.hb.open span:nth-child(2){opacity:0}
.hb.open span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px)}
@media(max-width:768px){.nl,.nb{display:none!important}.hb{display:flex}}

/* SIDEBAR */
.sb{position:fixed;top:0;right:-100%;width:min(300px,85vw);height:100%;background:#111;z-index:300;padding:var(--nav-h) 0 2rem;transition:right .35s cubic-bezier(.4,0,.2,1);border-left:1px solid var(--border);display:flex;flex-direction:column}
.sb.open{right:0}
.sbh{padding:1.5rem 1.75rem 1rem;border-bottom:1px solid rgba(255,255,255,.07)}
.sbh p{font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);font-weight:600}
.sbl{list-style:none;flex:1;padding:.5rem 0}
.sbl a{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.75rem;font-size:1rem;font-family:"Playfair Display",serif;color:rgba(255,255,255,.8);text-decoration:none;border-bottom:1px solid rgba(255,255,255,.05);transition:all .2s}
.sbl a:hover{color:var(--gold)}
.sbf{padding:1.5rem 1.75rem}
.sbf .btn{width:100%}
.ov{position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:250;opacity:0;pointer-events:none;transition:opacity .3s}
.ov.open{opacity:1;pointer-events:all}

/* HERO — tight, no extra space */
.hero{position:relative;padding-top:var(--nav-h);display:flex;align-items:center;background:#0d0d0d}
.hbg{position:absolute;inset:0;background-image:url("data:image/jpeg;base64,");background-size:cover;background-position:center top;opacity:.45;z-index:0}
.hbg::after{content:"";position:absolute;inset:0;background:linear-gradient(to bottom,rgba(13,13,13,.15) 0%,rgba(13,13,13,.05) 20%,rgba(13,13,13,.55) 60%,rgba(13,13,13,1) 95%)}
.hc{position:relative;z-index:2;width:100%;padding:clamp(3rem,8vw,5rem) 0 clamp(2.5rem,6vw,4rem);text-align:center}
.hey{display:flex;align-items:center;justify-content:center;gap:.75rem;margin-bottom:1rem}
.hey::before,.hey::after{content:"";display:block;height:1px;width:1.5rem;background:var(--gold)}
.hero h1{font-size:clamp(2rem,5.5vw,3.6rem);color:#fff;margin-bottom:1rem;text-shadow:0 2px 30px rgba(0,0,0,.5)}
.hl{font-size:.9rem;color:rgba(255,255,255,.72);margin:0 auto 1.75rem;max-width:480px;line-height:1.8}
.ha{display:flex;flex-direction:column;gap:.65rem;max-width:340px;margin:0 auto}
.ha .btn{width:100%}

/* SECTIONS */
.sec{padding:clamp(3rem,7vw,6rem) 0}
.sh{text-align:center;margin-bottom:clamp(1.75rem,4vw,3rem)}
.sh .ey{margin-bottom:.75rem;display:block}
.sh h2{font-size:clamp(1.7rem,3.5vw,2.8rem)}
.sh h2 span{color:var(--gold)}
.sh p{margin-top:.65rem;color:rgba(255,255,255,.4);font-size:.85rem;max-width:520px;margin-left:auto;margin-right:auto;line-height:1.7}

/* ABOUT — full image on desktop */
.about{background:var(--dark2)}
.ag{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start}
.aiw{position:relative}
.aiw::before{content:"";position:absolute;inset:-1rem 1rem 1rem -1rem;border:1px solid var(--border);z-index:0;pointer-events:none}
/* Full portrait — not cropped */
.ai{width:100%;object-fit:cover;object-position:center top;display:block;position:relative;z-index:1}
.at .ey{display:block;margin-bottom:.75rem}
.at h2{font-size:clamp(1.6rem,3vw,2.5rem);margin-bottom:1.25rem}
.at p{color:rgba(255,255,255,.6);font-size:.88rem;margin-bottom:.8rem;line-height:1.8}
.at strong{color:#fff;font-weight:500}
.aq{margin-top:1.5rem;padding:1.25rem;border-left:2px solid var(--gold);background:rgba(201,168,76,.06)}
.aq p{font-family:"Playfair Display",serif;font-style:italic;font-size:1rem;color:var(--gold2);margin:0}
@media(max-width:900px){.ag{grid-template-columns:1fr;gap:2rem}.aiw::before{display:none}}

/* COMPARE */
.cmp{background:var(--dark)}
.cg{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem}
.cc{padding:2rem;border:1px solid rgba(255,255,255,.07)}
.cc.old{background:#0f0f0f}
.cc.nw{background:rgba(201,168,76,.05);border-color:var(--border)}
.cl{font-size:.6rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase;margin-bottom:.6rem;display:block}
.cc.old .cl{color:rgba(255,255,255,.3)}
.cc.nw .cl{color:var(--gold)}
.cc h3{font-size:1.2rem;margin-bottom:.75rem}
.cc.old h3{color:rgba(255,255,255,.45)}
.cc p{font-size:.85rem;color:rgba(255,255,255,.5);line-height:1.75}
.cc.nw p{color:rgba(255,255,255,.65)}
.cc ul{list-style:none;margin-top:1rem;display:flex;flex-direction:column;gap:.45rem}
.cc li{font-size:.82rem;color:rgba(255,255,255,.7);padding-left:1.5rem;position:relative}
.cc li::before{content:"✓";position:absolute;left:0;color:var(--gold)}
.ci{margin-top:1.25rem;overflow:hidden}
.ci img{width:100%;height:200px;object-fit:cover;display:block}
@media(max-width:768px){.cg{grid-template-columns:1fr}}

/* PRICING — carousel on ALL devices */
.pricing{background:var(--dark2)}
/* Carousel wrapper — scrolls horizontally, centered when space allows */
.pwrap{overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:thin;scrollbar-color:var(--gold) rgba(255,255,255,.05);padding:1.5rem clamp(1.25rem,5vw,3rem) 1.5rem}
.pwrap::-webkit-scrollbar{height:3px}
.pwrap::-webkit-scrollbar-track{background:rgba(255,255,255,.04)}
.pwrap::-webkit-scrollbar-thumb{background:var(--gold);border-radius:2px}
/* Inner grid — min-content so cards don't stretch */
.pgrid{display:inline-flex;gap:1rem;min-width:max-content;align-items:flex-start}
/* On large screens, center the carousel */
@media(min-width:1500px){
  .pwrap{display:flex;justify-content:center}
  .pgrid{min-width:unset}
}

/* PLAN CARD — compact, square-ish */
.pc{position:relative;background:#141414;border:1px solid rgba(255,255,255,.09);border-radius:4px;width:230px;flex-shrink:0;display:flex;flex-direction:column;transition:border-color .25s,transform .25s;margin-top:18px}
.pc:hover{border-color:rgba(201,168,76,.35);transform:translateY(-3px)}
.pc.pop{border-color:var(--gold);background:#161410}
.pc.eli{background:linear-gradient(155deg,#1a1508 0%,#141414 55%);border-color:var(--gold);box-shadow:0 0 30px rgba(201,168,76,.12)}
/* Badge */
.pb{position:absolute;top:-14px;left:50%;transform:translateX(-50%);white-space:nowrap;font-family:"Inter",sans-serif;font-size:.55rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;padding:.28rem .9rem;border-radius:20px;z-index:2}
.pb.pop{background:var(--gold);color:#0d0d0d}
.pb.eli{background:linear-gradient(90deg,#b8860b,var(--gold),#f0d060,var(--gold),#b8860b);background-size:200% auto;color:#0d0d0d;animation:shine 3s linear infinite;box-shadow:0 2px 10px rgba(201,168,76,.35)}
@keyframes shine{0%{background-position:0% center}100%{background-position:200% center}}
/* Card top */
.pt{padding:1.5rem 1.5rem 1.1rem}
.pc.pop .pt,.pc.eli .pt{padding-top:1.9rem}
.pla{font-size:.58rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:.2rem}
.pn{font-family:"Playfair Display",serif;font-size:1.3rem;font-weight:700;color:#fff;margin-bottom:.5rem}
.pc.eli .pn{color:var(--gold2)}
.pdesc{font-size:.78rem;color:rgba(255,255,255,.45);line-height:1.6;margin-bottom:.9rem}
.ppr{display:flex;align-items:flex-end;gap:.35rem}
.pam{font-family:"Playfair Display",serif;font-size:2.1rem;font-weight:400;color:#fff;line-height:1}
.pc.eli .pam{color:var(--gold);font-size:2.4rem}
.pper{font-size:.75rem;color:rgba(255,255,255,.3);padding-bottom:.2rem}
/* Features */
.pf{list-style:none;padding:0 1.5rem;display:flex;flex-direction:column;flex:1}
.fi{display:flex;gap:.6rem;align-items:flex-start;padding:.55rem 0;border-top:1px solid rgba(255,255,255,.05)}
.fck{flex-shrink:0;color:var(--gold);font-size:.65rem;width:14px;height:14px;display:flex;align-items:center;justify-content:center;background:rgba(201,168,76,.12);border-radius:50%;margin-top:.1rem;font-weight:700}
.ft strong{font-size:.77rem;color:#fff;font-weight:500;line-height:1.35;display:block}
.ft span{font-size:.71rem;color:rgba(255,255,255,.32);line-height:1.45;display:none}
/* Toggle */
.ptg{margin:.75rem 1.5rem 0;background:none;border:none;color:var(--gold);font-size:.7rem;font-family:"Inter",sans-serif;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:.35rem;padding:.55rem 0;border-top:1px solid rgba(255,255,255,.06);width:calc(100% - 3rem)}
.ptg:hover{color:var(--gold2)}
.ti{transition:transform .2s;font-size:.6rem}
.ptg.exp .ti{transform:rotate(180deg)}
/* CTA */
.pct{display:block;text-align:center;margin:.75rem 1.5rem 1.5rem;padding:.7rem;font-size:.7rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;border-radius:3px;border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.7);transition:all .2s}
.pct:hover{background:rgba(255,255,255,.05)}
.pc.pop .pct{background:var(--gold);border-color:var(--gold);color:#0d0d0d}
.pc.pop .pct:hover{background:var(--gold2)}
.pc.eli .pct{background:linear-gradient(90deg,var(--gold),var(--gold2),var(--gold));background-size:200% auto;border-color:transparent;color:#0d0d0d;animation:shine 3s linear infinite}

/* FEATURES */
.feat{background:var(--dark)}
.fg{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem}
.fb{padding:1.75rem;border:1px solid rgba(255,255,255,.07);border-radius:3px;transition:border-color .25s,background .25s}
.fb:hover{border-color:var(--border);background:rgba(201,168,76,.04)}
.fi2{font-size:1.3rem;margin-bottom:.75rem;display:block}
.fb h3{font-size:1rem;margin-bottom:.4rem;color:#fff}
.fb p{font-size:.8rem;color:rgba(255,255,255,.45);line-height:1.7}

/* FAQ */
.faq{background:var(--dark2)}
.fl{max-width:700px;margin:0 auto}
.fqi{border-bottom:1px solid var(--border)}
.fqq{width:100%;background:none;border:none;padding:1.2rem 0;display:flex;align-items:center;justify-content:space-between;gap:1rem;cursor:pointer;font-family:"Playfair Display",serif;font-size:1rem;color:#fff;text-align:left;transition:color .2s}
.fqq:hover{color:var(--gold)}
.fqi2{flex-shrink:0;width:26px;height:26px;border:1px solid var(--border);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--gold);transition:transform .25s;font-size:.9rem}
.fqi.open .fqi2{transform:rotate(45deg)}
.fqa{display:none;padding:0 0 1.2rem;font-size:.85rem;color:rgba(255,255,255,.5);line-height:1.8}
.fqi.open .fqa{display:block}
.fc{text-align:center;margin-top:2.5rem}

/* CTA */
.cta{padding:clamp(3.5rem,8vw,7rem) 0;background:var(--dark);text-align:center;position:relative;overflow:hidden}
.cta::before{content:"";position:absolute;inset:0;background:radial-gradient(ellipse 70% 70% at 50% 50%,rgba(201,168,76,.09) 0%,transparent 60%)}
.cta .con{position:relative;z-index:1}
.cta .ey{display:block;margin-bottom:1rem}
.cta h2{font-size:clamp(1.9rem,4.5vw,3.5rem);margin-bottom:1.75rem}
.cta h2 span{color:var(--gold)}
.cs{margin-top:1.5rem;font-size:.75rem;color:rgba(255,255,255,.22);letter-spacing:.05em}

/* FOOTER */
footer{background:#080808;padding:2rem 0;border-top:1px solid rgba(255,255,255,.05)}
.fi3{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem}
.flo img{height:32px;width:auto;opacity:.4}
.fli{display:flex;gap:1.5rem;list-style:none;flex-wrap:wrap}
.fli a{font-size:.7rem;color:rgba(255,255,255,.28);text-decoration:none;transition:color .2s}
.fli a:hover{color:rgba(255,255,255,.6)}
.fco{font-size:.68rem;color:rgba(255,255,255,.18)}

/* REVEAL */
.rv{opacity:0;transform:translateY(18px);transition:opacity .6s ease,transform .6s ease}
.rv.in{opacity:1;transform:none}
@media(prefers-reduced-motion:reduce){.rv{opacity:1;transform:none}}

/* GHL white bottom fix */
html{margin-bottom:0!important;padding-bottom:0!important}
body{margin-bottom:0!important;padding-bottom:0!important}
footer{margin-bottom:0!important;padding-bottom:0!important}
</style>
</head>
